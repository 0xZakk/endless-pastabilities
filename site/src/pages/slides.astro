---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Endless Pastabilities — Presentation</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="slides-body">

    <!-- ── Slide 1: Title ──────────────────────────────────── -->
    <section class="slide slide--title" data-slide="1">
      <div class="slide-content">
        <div class="title-decoration">~</div>
        <h1>Endless Pastabilities</h1>
        <p class="subtitle">Building a pasta encyclopedia with NLP,<br/>vector search, and 4.5 million characters of Italian wisdom.</p>
        <div class="title-decoration">~</div>
        <div class="slide-footer-info">
          <span>Hackathon 2026</span>
        </div>
      </div>
    </section>

    <!-- ── Slide 2: The Problem ────────────────────────────── -->
    <section class="slide" data-slide="2">
      <div class="slide-content">
        <h3>The Challenge</h3>
        <h2>How many pasta shapes are there?</h2>
        <div class="big-quote">
          <p>"Anything from 350 to 600 depending on who is counting."</p>
          <cite>— Rachel Roddy, An A-Z of Pasta</cite>
        </div>
        <p class="slide-text">
          The knowledge is scattered across dozens of books, in multiple languages,
          with inconsistent naming, regional dialects, and overlapping traditions.
        </p>
        <p class="slide-text">
          <strong>Our goal:</strong> Build a single, beautiful encyclopedia that synthesizes
          everything — descriptions, shaping instructions, history — from the best sources.
        </p>
      </div>
    </section>

    <!-- ── Slide 3: The Sources ────────────────────────────── -->
    <section class="slide" data-slide="3">
      <div class="slide-content">
        <h3>Source Material</h3>
        <h2>8 Books. 4.5 Million Characters.</h2>
        <div class="source-grid">
          <div class="source-card">
            <strong>Encyclopedia of Pasta</strong>
            <span>Zanini De Vita</span>
            <span class="source-detail">877K chars · 398 pages · The definitive reference</span>
          </div>
          <div class="source-card">
            <strong>An A-Z of Pasta</strong>
            <span>Rachel Roddy</span>
            <span class="source-detail">678K chars · Narrative + recipes per shape</span>
          </div>
          <div class="source-card">
            <strong>Encyclopedia of Pasta</strong>
            <span>Coastal Kitchen</span>
            <span class="source-detail">1.27M chars · 350+ recipes with technique</span>
          </div>
          <div class="source-card">
            <strong>Mastering Pasta</strong>
            <span>Marc Vetri</span>
            <span class="source-detail">595K chars · Flour science + dough craft</span>
          </div>
          <div class="source-card">
            <strong>Pasta Grannies</strong>
            <span>Vicky Bennison</span>
            <span class="source-detail">337K chars · Regional grandmother traditions</span>
          </div>
          <div class="source-card">
            <strong>Pasta By Hand</strong>
            <span>Jenn Louis</span>
            <span class="source-detail">273K chars · Hand-shaped technique focus</span>
          </div>
          <div class="source-card">
            <strong>Pasta & Noodles</strong>
            <span>Kantha Shelke</span>
            <span class="source-detail">217K chars · Global history</span>
          </div>
          <div class="source-card">
            <strong>Pasta</strong>
            <span>Theo Randall</span>
            <span class="source-detail">251K chars · Chef's recipes by shape</span>
          </div>
        </div>
        <p class="slide-text center"><strong>3 PDFs + 5 EPUBs</strong> — two different extraction pipelines needed.</p>
      </div>
    </section>

    <!-- ── Slide 4: Architecture ───────────────────────────── -->
    <section class="slide" data-slide="4">
      <div class="slide-content">
        <h3>Architecture</h3>
        <h2>The Pipeline</h2>
        <div class="pipeline-diagram">
          <div class="pipeline-step">
            <div class="step-number">1</div>
            <div class="step-body">
              <strong>Extract</strong>
              <span>PDFs + EPUBs → structured JSON</span>
            </div>
          </div>
          <div class="pipeline-arrow">▼</div>
          <div class="pipeline-step">
            <div class="step-number">2</div>
            <div class="step-body">
              <strong>Chunk & Embed</strong>
              <span>4,602 vectors in ChromaDB</span>
            </div>
          </div>
          <div class="pipeline-arrow">▼</div>
          <div class="pipeline-step split">
            <div class="pipeline-step">
              <div class="step-number">3</div>
              <div class="step-body">
                <strong>Extract Shapes</strong>
                <span>983 → 319 → 123 curated</span>
              </div>
            </div>
            <div class="pipeline-step">
              <div class="step-number">4</div>
              <div class="step-body">
                <strong>Extract Doughs</strong>
                <span>10 canonical recipes</span>
              </div>
            </div>
          </div>
          <div class="pipeline-arrow">▼</div>
          <div class="pipeline-step">
            <div class="step-number">5</div>
            <div class="step-body">
              <strong>Assemble Knowledge</strong>
              <span>Semantic search → synthesize per shape</span>
            </div>
          </div>
          <div class="pipeline-arrow">▼</div>
          <div class="pipeline-step">
            <div class="step-number">6</div>
            <div class="step-body">
              <strong>Generate Site</strong>
              <span>Astro → 136 static pages in 512ms</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 5: Text Extraction ────────────────────────── -->
    <section class="slide" data-slide="5">
      <div class="slide-content">
        <h3>Phase 1</h3>
        <h2>Text Extraction</h2>
        <div class="stat-row">
          <div class="stat-block">
            <div class="stat-val">8</div>
            <div class="stat-lbl">Books</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">4.5M</div>
            <div class="stat-lbl">Characters</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">2</div>
            <div class="stat-lbl">Engines</div>
          </div>
        </div>
        <div class="two-col">
          <div class="col">
            <h4>PDFs</h4>
            <p class="slide-text"><strong>PyMuPDF</strong> — primary text extraction with superior layout handling.</p>
            <p class="slide-text"><strong>pdfplumber</strong> — parallel run for table and structured data capture.</p>
            <p class="slide-text">Results merged: PyMuPDF text + pdfplumber tables.</p>
          </div>
          <div class="col">
            <h4>EPUBs</h4>
            <p class="slide-text"><strong>ebooklib</strong> — unpacks EPUB containers, iterates document items.</p>
            <p class="slide-text"><strong>BeautifulSoup</strong> — parses XHTML to clean text, preserving structure.</p>
            <p class="slide-text">Headings, lists, and hierarchy maintained.</p>
          </div>
        </div>
        <pre class="slide-code">{`Output: 8 JSON files with metadata, sections, page numbers, and character counts.`}</pre>
      </div>
    </section>

    <!-- ── Slide 6: Chunking & Embedding ───────────────────── -->
    <section class="slide" data-slide="6">
      <div class="slide-content">
        <h3>Phase 2</h3>
        <h2>Chunking & Embedding</h2>
        <div class="stat-row">
          <div class="stat-block">
            <div class="stat-val">4,602</div>
            <div class="stat-lbl">Chunks</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">384</div>
            <div class="stat-lbl">Dimensions</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">~800</div>
            <div class="stat-lbl">Chars/chunk</div>
          </div>
        </div>
        <div class="chunk-diagram">
          <pre class="slide-code">{`
  ┌──────────────────────────────────────────────────┐
  │ Paragraph A │ Paragraph B │ Paragraph C │ ...    │  Raw text
  └──────────────────────────────────────────────────┘

       ┌───── chunk 1 ─────┐
                     ┌─overlap─┐
                     ┌───── chunk 2 ─────┐
                                  ┌─overlap─┐
                                  ┌───── chunk 3 ─────┐

  ~800 chars per chunk · 150 char overlap · paragraph-boundary splitting
          `}</pre>
        </div>
        <div class="two-col">
          <div class="col">
            <h4>Embedding Model</h4>
            <p class="slide-text"><strong>all-MiniLM-L6-v2</strong> — 22M parameters, 384-dim vectors. Fast, accurate, runs locally via ONNX.</p>
          </div>
          <div class="col">
            <h4>Vector Store</h4>
            <p class="slide-text"><strong>ChromaDB</strong> — persistent, file-based. ~50MB on disk. Approximate nearest-neighbor search.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 7: Semantic Search Demo ───────────────────── -->
    <section class="slide" data-slide="7">
      <div class="slide-content">
        <h3>Phase 2</h3>
        <h2>Semantic Search in Action</h2>
        <p class="slide-text">The vector store enables cross-book retrieval with natural language queries.</p>
        <div class="search-demo">
          <div class="search-query">Query: "orecchiette from Puglia"</div>
          <div class="search-results">
            <div class="search-result">
              <span class="result-score">0.764</span>
              <span class="result-book">An A-Z of Pasta</span>
              <span class="result-text">"My friend never wants to go back to her home town in Puglia, but when I went..."</span>
            </div>
            <div class="search-result">
              <span class="result-score">0.856</span>
              <span class="result-book">Pasta (Randall)</span>
              <span class="result-text">"Orecchiette with Duck..."</span>
            </div>
            <div class="search-result">
              <span class="result-score">0.880</span>
              <span class="result-book">An A-Z of Pasta</span>
              <span class="result-text">"Impara l'arte e mettila da parte, learn the art, and store it..."</span>
            </div>
          </div>
          <div class="search-query">Query: "egg pasta dough recipe"</div>
          <div class="search-results">
            <div class="search-result">
              <span class="result-score">0.559</span>
              <span class="result-book">Mastering Pasta</span>
              <span class="result-text">"WHOLE EGG AND EGG YOLK DOUGH — For some added richness..."</span>
            </div>
            <div class="search-result">
              <span class="result-score">0.561</span>
              <span class="result-book">Pasta Grannies</span>
              <span class="result-text">"Add 4g (1 teaspoon) salt to a litre warm water..."</span>
            </div>
            <div class="search-result">
              <span class="result-score">0.564</span>
              <span class="result-book">Mastering Pasta</span>
              <span class="result-text">"So a basic recipe would be 300 grams of flour, 3 eggs..."</span>
            </div>
          </div>
        </div>
        <p class="slide-text center text-small">Lower distance = higher relevance. Finds content across all 8 books.</p>
      </div>
    </section>

    <!-- ── Slide 8: Entity Extraction ──────────────────────── -->
    <section class="slide" data-slide="8">
      <div class="slide-content">
        <h3>Phase 3 & 4</h3>
        <h2>Entity Extraction</h2>
        <div class="two-col">
          <div class="col">
            <h4>Pasta Shapes</h4>
            <div class="funnel">
              <div class="funnel-step funnel-wide">
                <span class="funnel-val">983</span>
                <span class="funnel-lbl">Raw candidates</span>
              </div>
              <div class="funnel-step funnel-med">
                <span class="funnel-val">382</span>
                <span class="funnel-lbl">After dedup</span>
              </div>
              <div class="funnel-step funnel-narrow">
                <span class="funnel-val">123</span>
                <span class="funnel-lbl">Curated shapes</span>
              </div>
            </div>
            <p class="slide-text">Source-specific extractors per book structure. Normalized names, merged aliases. Classified into: hand-shaped, hand-cut, filled, extruded, sheet, dumpling, small.</p>
          </div>
          <div class="col">
            <h4>Dough Recipes</h4>
            <div class="funnel">
              <div class="funnel-step funnel-wide">
                <span class="funnel-val">213</span>
                <span class="funnel-lbl">Dough-related chunks</span>
              </div>
              <div class="funnel-step funnel-med">
                <span class="funnel-val">17</span>
                <span class="funnel-lbl">Targeted queries</span>
              </div>
              <div class="funnel-step funnel-narrow">
                <span class="funnel-val">10</span>
                <span class="funnel-lbl">Canonical doughs</span>
              </div>
            </div>
            <p class="slide-text">Semantic-search-first approach. Keyword scoring to classify chunks into dough types. Cross-referenced ingredients from multiple books.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 9: Knowledge Assembly ─────────────────────── -->
    <section class="slide" data-slide="9">
      <div class="slide-content">
        <h3>Phase 5</h3>
        <h2>Knowledge Assembly</h2>
        <div class="stat-row">
          <div class="stat-block">
            <div class="stat-val">5,272</div>
            <div class="stat-lbl">Chunks gathered</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">~43</div>
            <div class="stat-lbl">Chunks/shape</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">100%</div>
            <div class="stat-lbl">Coverage</div>
          </div>
        </div>
        <p class="slide-text">For each shape, 4 semantic queries gather evidence from every book:</p>
        <pre class="slide-code">{`
  "{shape} pasta"                              → general info
  "{shape} how to make shape dough"            → technique
  "{shape} history origin region tradition"    → cultural context
  "{shape} ingredients recipe"                 → recipe details
        `}</pre>
        <p class="slide-text">Then synthesize into 3 structured fields:</p>
        <div class="three-cards">
          <div class="mini-card">
            <strong>Description</strong>
            <span>What it looks like (1-2 sentences)</span>
          </div>
          <div class="mini-card">
            <strong>Instructions</strong>
            <span>Step-by-step shaping (5-8 steps)</span>
          </div>
          <div class="mini-card">
            <strong>History</strong>
            <span>Origins & tradition (2-4 sentences)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 10: Worked Example ────────────────────────── -->
    <section class="slide" data-slide="10">
      <div class="slide-content">
        <h3>Example</h3>
        <h2>Assembling Orecchiette</h2>
        <div class="example-flow">
          <div class="example-sources">
            <h4>Evidence from 7 books:</h4>
            <div class="evidence-list">
              <div class="evidence-item"><strong>Encyclopedia of Pasta</strong> — Entry #28, etymology, regional spread</div>
              <div class="evidence-item"><strong>An A-Z of Pasta</strong> — Angevin Provence connection, Arco Basso</div>
              <div class="evidence-item"><strong>Pasta By Hand</strong> — Detailed shaping technique</div>
              <div class="evidence-item"><strong>Mastering Pasta</strong> — Finger technique, texture notes</div>
              <div class="evidence-item"><strong>Pasta Grannies</strong> — Street-side making in Bari</div>
              <div class="evidence-item"><strong>Pasta (Randall)</strong> — Recipe with duck sauce</div>
              <div class="evidence-item"><strong>Coastal Encyclopedia</strong> — Additional variations</div>
            </div>
          </div>
          <div class="example-arrow">→</div>
          <div class="example-output">
            <h4>Synthesized output:</h4>
            <div class="output-preview">
              <p><strong>Description:</strong> <em>"Small, ear-shaped pasta with a thin center and thicker rim, created by pressing and dragging small pieces of dough with the thumb."</em></p>
              <p><strong>Instructions:</strong> <em>7 steps — from making semolina dough to the characteristic thumb-drag-and-invert technique.</em></p>
              <p><strong>History:</strong> <em>"Meaning 'little ears,' possibly traced to the crosets of medieval Provence, brought by the Angevins. First mentioned by Giambattista del Tufo in the 1500s. Women of Arco Basso in Old Bari still make them on the street."</em></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 11: The Website ───────────────────────────── -->
    <section class="slide" data-slide="11">
      <div class="slide-content">
        <h3>Phase 6</h3>
        <h2>The Website</h2>
        <div class="stat-row">
          <div class="stat-block">
            <div class="stat-val">136</div>
            <div class="stat-lbl">Pages</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">512ms</div>
            <div class="stat-lbl">Build time</div>
          </div>
          <div class="stat-block">
            <div class="stat-val">0 KB</div>
            <div class="stat-lbl">Client JS</div>
          </div>
        </div>
        <div class="two-col">
          <div class="col">
            <h4>Design</h4>
            <p class="slide-text">Minimal, elevated, classic. Warm off-white (<code>#fafaf8</code>), serif typography, generous white space, thin horizontal rules. Inspired by printed encyclopedias and botanical field guides.</p>
          </div>
          <div class="col">
            <h4>Tech</h4>
            <p class="slide-text"><strong>Astro 6</strong> — static site generation. Single JSON data file consumed at build time. Zero client-side JavaScript. Scoped CSS with custom properties. System font stacks.</p>
          </div>
        </div>
        <div class="three-cards">
          <div class="mini-card">
            <strong>123 Shape Pages</strong>
            <span>Description, instructions, history, dough link</span>
          </div>
          <div class="mini-card">
            <strong>10 Dough Pages</strong>
            <span>Full recipes with ingredients, method, tips</span>
          </div>
          <div class="mini-card">
            <strong>Index Pages</strong>
            <span>Browse by category, dough overview, about</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 12: Tech Stack ────────────────────────────── -->
    <section class="slide" data-slide="12">
      <div class="slide-content">
        <h3>Infrastructure</h3>
        <h2>Tech Stack</h2>
        <div class="two-col">
          <div class="col">
            <h4>Data Pipeline</h4>
            <table class="slide-table">
              <tr><td>PDF</td><td>PyMuPDF + pdfplumber</td></tr>
              <tr><td>EPUB</td><td>ebooklib + BeautifulSoup</td></tr>
              <tr><td>Chunks</td><td>Custom paragraph splitter</td></tr>
              <tr><td>Embeddings</td><td>all-MiniLM-L6-v2</td></tr>
              <tr><td>Vector DB</td><td>ChromaDB</td></tr>
              <tr><td>NER</td><td>Pattern + heuristic NLP</td></tr>
              <tr><td>Assembly</td><td>Semantic retrieval + synthesis</td></tr>
            </table>
          </div>
          <div class="col">
            <h4>Website</h4>
            <table class="slide-table">
              <tr><td>Framework</td><td>Astro 6</td></tr>
              <tr><td>Styling</td><td>Scoped CSS + custom props</td></tr>
              <tr><td>Typography</td><td>System serif stack</td></tr>
              <tr><td>JavaScript</td><td>None (static HTML)</td></tr>
              <tr><td>Data</td><td>Single JSON at build time</td></tr>
              <tr><td>External APIs</td><td>Zero</td></tr>
              <tr><td>Build</td><td>512ms</td></tr>
            </table>
          </div>
        </div>
        <p class="slide-text center"><strong>Entirely local.</strong> No API keys. No cloud services. No external dependencies at runtime.</p>
      </div>
    </section>

    <!-- ── Slide 13: By the Numbers ────────────────────────── -->
    <section class="slide" data-slide="13">
      <div class="slide-content">
        <h3>Results</h3>
        <h2>By the Numbers</h2>
        <div class="numbers-grid">
          <div class="number-card">
            <div class="number-val">4.5M</div>
            <div class="number-lbl">Characters extracted</div>
          </div>
          <div class="number-card">
            <div class="number-val">4,602</div>
            <div class="number-lbl">Semantic chunks</div>
          </div>
          <div class="number-card">
            <div class="number-val">123</div>
            <div class="number-lbl">Pasta shapes</div>
          </div>
          <div class="number-card">
            <div class="number-val">10</div>
            <div class="number-lbl">Dough recipes</div>
          </div>
          <div class="number-card">
            <div class="number-val">100%</div>
            <div class="number-lbl">Content coverage</div>
          </div>
          <div class="number-card">
            <div class="number-val">136</div>
            <div class="number-lbl">Generated pages</div>
          </div>
          <div class="number-card">
            <div class="number-val">8</div>
            <div class="number-lbl">Source books</div>
          </div>
          <div class="number-card">
            <div class="number-val">0</div>
            <div class="number-lbl">External APIs</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 14: What's Next ───────────────────────────── -->
    <section class="slide" data-slide="14">
      <div class="slide-content">
        <h3>Future</h3>
        <h2>What's Next</h2>
        <div class="next-items">
          <div class="next-item">
            <div class="next-icon">🎨</div>
            <div>
              <strong>Watercolor Illustrations</strong>
              <p class="slide-text">AI-generated botanical-style illustrations for each shape. Think scientific field guide meets pasta encyclopedia.</p>
            </div>
          </div>
          <div class="next-item">
            <div class="next-icon">📖</div>
            <div>
              <strong>More Sources</strong>
              <p class="slide-text">Two books had corrupted downloads (Missy Robbins, Mateo Zielonka). Re-acquiring would add more shapes and techniques.</p>
            </div>
          </div>
          <div class="next-item">
            <div class="next-icon">🔍</div>
            <div>
              <strong>Sauce Pairings</strong>
              <p class="slide-text">Extract sauce-to-shape pairings from the sources. Which shapes hold which sauces best, and why.</p>
            </div>
          </div>
          <div class="next-item">
            <div class="next-icon">🗺️</div>
            <div>
              <strong>Regional Map</strong>
              <p class="slide-text">Interactive map of Italy showing which shapes come from which regions.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Slide 15: End ───────────────────────────────────── -->
    <section class="slide slide--title" data-slide="15">
      <div class="slide-content">
        <div class="title-decoration">~</div>
        <h1>The Pastabilities<br/>are Endless</h1>
        <p class="subtitle">endlesspastabilities.com</p>
        <div class="title-decoration">~</div>
      </div>
    </section>

    <!-- ── Navigation ──────────────────────────────────────── -->
    <div class="slide-nav">
      <button id="prev" class="nav-btn">&larr;</button>
      <span id="indicator" class="nav-indicator">1 / 15</span>
      <button id="next" class="nav-btn">&rarr;</button>
    </div>

    <script>
      const slides = document.querySelectorAll('.slide');
      const total = slides.length;
      let current = 0;

      function showSlide(n: number) {
        current = Math.max(0, Math.min(n, total - 1));
        slides.forEach((s, i) => {
          (s as HTMLElement).style.display = i === current ? 'flex' : 'none';
        });
        (document.getElementById('indicator') as HTMLElement).textContent = `${current + 1} / ${total}`;
      }

      document.getElementById('prev')?.addEventListener('click', () => showSlide(current - 1));
      document.getElementById('next')?.addEventListener('click', () => showSlide(current + 1));

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'ArrowDown') {
          e.preventDefault();
          showSlide(current + 1);
        }
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
